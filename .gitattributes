# crlf for Windows, lf for Unix
* text=auto eol=lf
*.{cmd,[cC][mM][dD]} text eol=crlf
*.{bat,[bB][aA][tT]} text eol=crlf
*.{vcxproj,vcxproj.filters} text eol=crlf

*.c     text
*.cpp   text
*.h     text
*.hpp   text
*.cc    text
*.hh    text

*.msg   text
*.srv   text
*.action text

CMakeLists.txt text
*.cmake text

*.nix text

*.py text

# Shell scripts
*.sh text

# Binary assets
*.stp binary
*.step binary
*.igs binary
*.iges binary
*.stl binary
*.blend binary
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.hex binary
*.bin binary
*.elf binary

